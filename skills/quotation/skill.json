{
  "name": "quotation",
  "version": "0.2.0",
  "description": "Generate modern quotation PDFs from JSON data",
  "author": "Lucy",
  "commands": [
    {
      "name": "generate",
      "pattern": "quotation generate",
      "handler": "./scripts/generate-quotation-modern.py",
      "args": ["{{ attachment.path }}", "output.pdf"]
    }
  ]
}